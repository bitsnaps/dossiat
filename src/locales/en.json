    "recurrentItem1": "Auto-renewal calendar",
    "recurrentItem2": "\"Pay the bill on the 5th\" — done",
    "recurrentItem3": "Pause / resume any time",
    "agreementTitle": "Checkbox Agreement",
    "agreementDesc": "Before any work begins, both parties tick a simple checklist that acts as a mutual digital agreement.",
    "agreementItem1": "Scope + confidentiality",
