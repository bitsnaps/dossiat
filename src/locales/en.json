  "workflow": {
    "sectionLabel": "Workflow",
    "title": "From invite to invoice, in four moves.",
    "subtitle": "No public marketplace noise. Clients are introduced by Agents they already know — or by the Agents they find through them.",
    "step1Label": "01 — INVITE",
    "step1Title": "Share the link",
